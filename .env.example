# ══════════════════════════════════════════════════════════════
#  TruPharma Clinical Intelligence — Environment Variables
# ══════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in your values.
#  NEVER commit the .env file to version control.

# ── Neo4j Aura (optional — auto-detected when NEO4J_URI is set) ──
#  Create a free instance at: https://console.neo4j.io
#  Aura Free limits: 200K nodes, 400K relationships
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here
NEO4J_DATABASE=neo4j

# ── Google Gemini API Key (optional — fallback when Vertex AI unavailable) ──
#  Required for: LLM-powered RAG answers, label interaction extraction
#  Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
# Alternative name (fallback):
# GOOGLE_API_KEY=your-key

# ── Vertex AI (preferred — replaces direct Gemini API) ──
#  Provides: embeddings (text-embedding-004) + LLM (gemini-2.0-flash)
#  Enable a GCP project with Vertex AI API enabled
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#  For Streamlit Cloud: set GCP_SERVICE_ACCOUNT_JSON in st.secrets instead

# ── Pinecone (optional — vector cache for faster repeat queries) ──
#  Free tier: ~100K vectors (768-dim), supports ~1000-2000 cached drugs
#  Sign up at: https://www.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=trupharma

# ── Streamlit Secrets (alternative to env vars) ──
#  You can also configure secrets in .streamlit/secrets.toml
#  See: https://docs.streamlit.io/develop/api-reference/connections/secrets
